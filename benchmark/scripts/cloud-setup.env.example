# GGLite Benchmark — Cloud Setup Environment Variables
#
# HOW TO USE:
#   1. cp cloud-setup.env.example cloud-setup.env
#   2. Edit cloud-setup.env with your values
#   3. cloud-setup.env is gitignored — NEVER commit it
#
# SETUP:
#   Create your own benchmark resources with these commands
#   (replace <ACCOUNT_ID> with your AWS account ID):
#
#   # S3 bucket
#   aws s3api create-bucket --bucket gglite-benchmark-<ACCOUNT_ID>-us-west-2 \
#     --region us-west-2 --create-bucket-configuration LocationConstraint=us-west-2
#   aws s3api put-bucket-versioning --bucket gglite-benchmark-<ACCOUNT_ID>-us-west-2 \
#     --versioning-configuration Status=Enabled
#   aws s3api put-public-access-block --bucket gglite-benchmark-<ACCOUNT_ID>-us-west-2 \
#     --public-access-block-configuration BlockPublicAcls=true,IgnorePublicAcls=true,BlockPublicPolicy=true,RestrictPublicBuckets=true
#
#   # IAM role for TES (trust credentials.iot.amazonaws.com)
#   aws iam create-role --role-name GGLite-Benchmark-TokenExchangeRole \
#     --assume-role-policy-document '{"Version":"2012-10-17","Statement":[{"Effect":"Allow","Principal":{"Service":"credentials.iot.amazonaws.com"},"Action":"sts:AssumeRole"}]}'
#   # Then attach an inline policy granting s3:PutObject/GetObject/ListBucket on your bucket + logs:Create*/PutLogEvents
#
#   # IoT role alias
#   aws iot create-role-alias --role-alias GGLite-Benchmark-TokenExchangeRoleAlias \
#     --role-arn arn:aws:iam::<ACCOUNT_ID>:role/GGLite-Benchmark-TokenExchangeRole --region us-west-2
#
#   # IoT Thing + cert + policy
#   aws iot create-thing --thing-name GGLite-Benchmark-Device-01 --region us-west-2
#   aws iot create-keys-and-certificate --set-as-active --region us-west-2  # save cert + key
#   aws iot create-policy --policy-name GGLite-Benchmark-Policy --policy-document file://iot-policy.json --region us-west-2
#   aws iot attach-thing-principal --thing-name GGLite-Benchmark-Device-01 --principal <CERT_ARN> --region us-west-2
#   aws iot attach-policy --policy-name GGLite-Benchmark-Policy --target <CERT_ARN> --region us-west-2
#
# ─────────────────────────────────────────────────────────────────────────────
# Shared team resources (if any): ask your team lead for a shared cloud-setup.env
# with values for an existing benchmark account. Otherwise, create your own
# resources using the commands above and fill in the placeholders below.
# ─────────────────────────────────────────────────────────────────────────────

# AWS region where IoT/S3/IAM resources live
GGL_AWS_REGION="us-west-2"

# IoT Thing name created for this device (customize per device if running multiple)
GGL_IOT_THING_NAME="GGLite-Benchmark-Device-01"

# IoT credential provider endpoint. Get via:
#   aws iot describe-endpoint --endpoint-type iot:CredentialProvider --region "$GGL_AWS_REGION" --query endpointAddress --output text
GGL_IOT_CRED_ENDPOINT="<REPLACE_ME>"

# IoT data endpoint (ATS). Get via:
#   aws iot describe-endpoint --endpoint-type iot:Data-ATS --region "$GGL_AWS_REGION" --query endpointAddress --output text
GGL_IOT_DATA_ENDPOINT="<REPLACE_ME>"

# IoT role alias pointing to the Token Exchange IAM role
GGL_IOT_ROLE_ALIAS="GGLite-Benchmark-TokenExchangeRoleAlias"

# S3 bucket used by the s3-uploader benchmark scenario
GGL_S3_BUCKET_NAME="<REPLACE_ME>"

# Local paths to the device cert/key issued for $GGL_IOT_THING_NAME
GGL_CERT_PATH="$HOME/.gglite-benchmark/cert.pem"
GGL_PRIVATE_KEY_PATH="$HOME/.gglite-benchmark/private.key"

# Local path to AmazonRootCA1.pem (downloaded automatically if unset/missing)
GGL_ROOT_CA_PATH="$HOME/.gglite-benchmark/AmazonRootCA1.pem"

# SSH config for reaching the target device
GGL_SSH_USER="ubuntu"
GGL_SSH_KEY=""  # empty = use ssh-agent
